# Backend API base URL (used by ChatAssistant for AI chat requests)
VITE_API_URL=

# WebSocket URL (used by the IDE terminal for live code execution)
VITE_WS_URL=

# GitHub repository URL (main language repo — links throughout the site)
VITE_GITHUB_REPO_URL=

# GitHub organization repository URL (organization-level repo link)
VITE_GITHUB_ORG_URL=

# GitHub releases page URL (download page for Linux/macOS)
VITE_GITHUB_RELEASES_URL=

# GitHub Code Explanation repository URL (ecosystem documentation repo)
VITE_GITHUB_CODE_EXPLANATION_URL=

# GitHub Docs Syncer repository URL (ecosystem automated docs tool)
VITE_GITHUB_DOCS_SYNCER_URL=

# GitHub author profile URL (footer attribution link)
VITE_GITHUB_AUTHOR_URL=

# Discord community invite URL
VITE_DISCORD_URL=

# Application display name (shown in branding throughout the site)
VITE_APP_NAME=Quantum

# Current application/language version (shown on download page and footer)
VITE_APP_VERSION=v2.0.4
